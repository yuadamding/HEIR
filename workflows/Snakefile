"""Minimal artifact workflow; heavyweight encoders remain explicit external stages."""

configfile: "../configs/experiments/natcommun_v0_1.yaml"

rule all:
    input:
        "../artifacts/B1/prototypes.npz",
        "../artifacts/B1/shared_svd.npz",
        "../outputs/demo/metrics.json",

rule validate_manifest:
    input:
        "../manifests/natcommun.tsv"
    output:
        touch("../artifacts/manifest.valid")
    shell:
        "heir validate-manifest {input} --require-folds --require-files && touch {output}"

rule prepare_b1_reference:
    input:
        manifest="../manifests/natcommun.tsv",
        panel="../manifests/gene_panel_example.tsv",
        validated="../artifacts/manifest.valid",
    output:
        "../artifacts/B1/reference.npz"
    shell:
        "heir prepare-reference --manifest {input.manifest} --section-id B1_4 "
        "--cell-type-key Level1 --genes {input.panel} --output {output}"

rule build_b1_prototypes:
    input:
        "../artifacts/B1/reference.npz"
    output:
        prototypes="../artifacts/B1/prototypes.npz",
        reference="../artifacts/B1/reference_latent.npz",
        transform="../artifacts/B1/shared_svd.npz",
    shell:
        "heir build-prototypes --reference {input} --output {output.prototypes} "
        "--reference-with-latent {output.reference} "
        "--fit-latent-transform {output.transform}"

rule executable_pipeline_smoke:
    output:
        checkpoint="../outputs/demo/heir_demo.pt",
        metrics="../outputs/demo/metrics.json",
    shell:
        "heir demo --output ../outputs/demo --epochs 1 --device cpu"
