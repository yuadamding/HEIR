{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heir.invalid/schemas/study_manifest.schema.json",
  "title": "HEIR two-stage locked study manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "study_id",
    "study_stage",
    "status",
    "hypothesis_ids",
    "git_commit",
    "analysis_plan_sha256",
    "container_digest",
    "dataset",
    "partitions",
    "observations",
    "candidate_target_gene_panel_sha256",
    "type_marker_panel_sha256",
    "randomization",
    "primary_endpoint",
    "secondary_endpoints",
    "coverage_requirements",
    "decision_thresholds",
    "lock_protection",
    "label_target_independence"
  ],
  "properties": {
    "schema": {"const": "heir.study_manifest.v2"},
    "study_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]{2,127}$"},
    "study_stage": {"enum": ["measurement_development", "confirmatory_morphology"]},
    "status": {"enum": ["draft", "locked", "opened"]},
    "hypothesis_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["H-MEAS", "H-REGIONAL", "H-CELL", "H-INTRINSIC", "H-REF", "H-END2END", "H-COMP", "H-EXT"]
      }
    },
    "git_commit": {"type": "string"},
    "analysis_plan_sha256": {"$ref": "#/$defs/sha256"},
    "container_digest": {"type": "string"},
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "source_study", "source_manifest_sha256"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "source_study": {"type": "string", "minLength": 1},
        "source_manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "partitions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["development_donors", "locked_test_donors", "external_test_donors", "split_manifest_sha256"],
      "properties": {
        "development_donors": {"$ref": "#/$defs/nonemptyStrings"},
        "locked_test_donors": {"$ref": "#/$defs/nonemptyStrings"},
        "external_test_donors": {"$ref": "#/$defs/strings"},
        "split_manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "registration_method", "target_variants", "broad_type_field", "fine_type_field"],
      "properties": {
        "level": {"type": "string", "minLength": 1},
        "registration_method": {"type": "string", "minLength": 1},
        "target_variants": {"$ref": "#/$defs/nonemptyStrings"},
        "broad_type_field": {"const": "broad_lineage"},
        "fine_type_field": {"const": "fine_type"},
        "supported_fine_type_ids": {"$ref": "#/$defs/strings"},
        "supported_fine_type_ids_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
      }
    },
    "candidate_target_gene_panel_sha256": {"$ref": "#/$defs/sha256"},
    "target_gene_panel_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "type_marker_panel_sha256": {"$ref": "#/$defs/sha256"},
    "target_panel_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "minimum_primary_gene_count",
        "fallback",
        "fallback_activation",
        "fallback_requires_new_h_meas_manifest",
        "fallback_requires_new_calibration",
        "locked_outcomes_may_inform_fallback"
      ],
      "properties": {
        "primary": {"const": "common_reliable_panel_across_all_supported_fine_types"},
        "minimum_primary_gene_count": {"type": "integer", "minimum": 1},
        "fallback": {"const": "new_study_version_type_specific_panels_or_prespecified_programs"},
        "fallback_activation": {"const": "only_after_development_h_meas_failure_before_any_confirmatory_opening"},
        "fallback_requires_new_h_meas_manifest": {"const": true},
        "fallback_requires_new_calibration": {"const": true},
        "locked_outcomes_may_inform_fallback": {"const": false}
      }
    },
    "encoder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_sha256", "feature_space_id", "checkpoint_sha256"],
      "properties": {
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "feature_space_id": {"type": "string", "minLength": 1},
        "checkpoint_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "crop_protocols": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/sha256"}
    },
    "reference_splits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_split_id", "split_ids"],
      "properties": {
        "primary_split_id": {"type": "string", "minLength": 1},
        "split_ids": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "technical_covariates": {"$ref": "#/$defs/strings"},
    "controls": {"$ref": "#/$defs/nonemptyStrings"},
    "hyperparameter_grid": {"type": "object", "minProperties": 1},
    "randomization": {"type": "object", "minProperties": 1},
    "primary_endpoint": {"type": "object", "minProperties": 1},
    "secondary_endpoints": {"type": "array"},
    "coverage_requirements": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "maximum_reference_evaluation_absolute_smd": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "maximum_reference_evaluation_categorical_total_variation": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_locked_donors_per_fine_type": {"type": "integer", "minimum": 0},
        "minimum_reference_cells_per_donor_section_type": {"type": "integer", "minimum": 1},
        "minimum_evaluation_cells_per_donor_section_type": {"type": "integer", "minimum": 1}
      }
    },
    "decision_thresholds": {"type": "object", "minProperties": 1},
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurement_report_sha256", "measurement_study_manifest_sha256", "measurement_source_sha256"],
      "properties": {
        "measurement_report_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "measurement_study_manifest_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "measurement_source_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
      }
    },
    "morphology_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_role",
        "scientific_scope",
        "final_inference",
        "calibration_receipt_sha256",
        "minimum_final_permutations",
        "minimum_coordinate_delta",
        "minimum_stain_delta",
        "minimum_null_shuffled_fraction",
        "minimum_strata_coverage",
        "minimum_expression_error_reduction",
        "minimum_basis_ceiling_r2",
        "maximum_direct_contrast_p",
        "minimum_mask_implementation_pass_fraction",
        "donor_bootstrap_iterations",
        "donor_bootstrap_seed",
        "prespecified_fixed_hyperparameters"
      ],
      "properties": {
        "experiment_role": {"type": "string", "minLength": 1},
        "scientific_scope": {"const": "registered_cell_local_context_association"},
        "final_inference": {"type": "boolean"},
        "calibration_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "minimum_final_permutations": {"type": "integer", "minimum": 1},
        "minimum_coordinate_delta": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_stain_delta": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_null_shuffled_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_strata_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_expression_error_reduction": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_basis_ceiling_r2": {"type": "number", "minimum": 0, "maximum": 1},
        "maximum_direct_contrast_p": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_mask_implementation_pass_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "donor_bootstrap_iterations": {"type": "integer", "minimum": 1},
        "donor_bootstrap_seed": {"type": "integer"},
        "prespecified_fixed_hyperparameters": {"type": "boolean"}
      }
    },
    "locked_measurement_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_timing",
        "selection_changes_forbidden",
        "coverage_denominator",
        "maximum_annotation_nucleus_p95_um",
        "maximum_annotation_cell_p95_um",
        "maximum_cell_nucleus_p95_um",
        "maximum_registration_nucleus_diameter_ratio_p95",
        "maximum_registration_nearest_neighbor_ratio_p95",
        "best_registration_quality_max_fraction_of_limit",
        "intermediate_registration_quality_max_fraction_of_limit",
        "maximum_registration_outlier_fraction",
        "maximum_nucleus_outside_cell_fraction",
        "minimum_nucleus_cell_area_ratio",
        "maximum_nucleus_cell_area_ratio",
        "maximum_segmentation_outlier_fraction",
        "maximum_crop_padding_p95",
        "mostly_padded_cutoff",
        "maximum_mostly_padded_fraction",
        "minimum_within_fine_type_reliability",
        "minimum_reliability_rows",
        "minimum_locked_donor_type_reliability_fraction"
      ],
      "properties": {
        "audit_timing": {"const": "after_confirmatory_lock_before_morphology_inference"},
        "selection_changes_forbidden": {"const": true},
        "coverage_denominator": {"const": "all_h_meas_supported_fine_types_and_locked_donors"},
        "maximum_annotation_nucleus_p95_um": {"const": 8.0},
        "maximum_annotation_cell_p95_um": {"const": 12.0},
        "maximum_cell_nucleus_p95_um": {"const": 8.0},
        "maximum_registration_nucleus_diameter_ratio_p95": {"const": 0.5},
        "maximum_registration_nearest_neighbor_ratio_p95": {"const": 0.5},
        "best_registration_quality_max_fraction_of_limit": {"const": 0.25},
        "intermediate_registration_quality_max_fraction_of_limit": {"const": 0.6},
        "maximum_registration_outlier_fraction": {"const": 0.05},
        "maximum_nucleus_outside_cell_fraction": {"const": 0.01},
        "minimum_nucleus_cell_area_ratio": {"const": 0.05},
        "maximum_nucleus_cell_area_ratio": {"const": 0.95},
        "maximum_segmentation_outlier_fraction": {"const": 0.05},
        "maximum_crop_padding_p95": {"const": 0.25},
        "mostly_padded_cutoff": {"const": 0.5},
        "maximum_mostly_padded_fraction": {"const": 0.01},
        "minimum_within_fine_type_reliability": {"const": 0.4},
        "minimum_reliability_rows": {"const": 40},
        "minimum_locked_donor_type_reliability_fraction": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
      }
    },
    "lock_protection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reserved_exclusively_for",
        "reserved_donor_ids",
        "prior_outcome_access_confirmed_false",
        "prior_outcome_access_status",
        "prior_outcome_exposure_receipt_sha256",
        "prospective_lock_eligible",
        "hescape_analysis_scope",
        "hescape_allowed_donor_ids",
        "forbidden_prior_outcome_uses"
      ],
      "properties": {
        "reserved_exclusively_for": {"const": "H-CELL"},
        "reserved_donor_ids": {"$ref": "#/$defs/nonemptyStrings"},
        "prior_outcome_access_confirmed_false": {"type": "boolean"},
        "prior_outcome_access_status": {
          "enum": ["unopened", "molecular_outcomes_materialized_pre_registration"]
        },
        "prior_outcome_exposure_receipt_sha256": {
          "anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        },
        "prospective_lock_eligible": {"type": "boolean"},
        "hescape_analysis_scope": {
          "enum": [
            "development_donors_only_hest_lock_unopened",
            "development_donors_only_reserved_outcomes_previously_materialized"
          ]
        },
        "hescape_allowed_donor_ids": {"$ref": "#/$defs/nonemptyStrings"},
        "forbidden_prior_outcome_uses": {"$ref": "#/$defs/nonemptyStrings"}
      }
    },
    "label_target_independence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "evidence_kind",
        "annotation_receipt_sha256",
        "ordered_annotation_feature_ids",
        "ordered_annotation_feature_ids_sha256",
        "ordered_target_gene_ids",
        "ordered_target_gene_ids_sha256",
        "annotation_target_overlap_count",
        "annotation_training_scope",
        "annotation_training_donor_ids",
        "annotation_training_donor_ids_sha256",
        "training_label_ontology_source",
        "training_label_provenance_receipt_sha256",
        "training_label_target_gene_overlap_count",
        "training_labels_establish_target_independence",
        "annotation_quality_contract",
        "locked_donors_used_for_training",
        "same_cohort_annotation",
        "cross_fitting_method",
        "cross_fitting_receipt_sha256",
        "establishes_full_target_independence",
        "limitation"
      ],
      "properties": {
        "strategy": {"type": "string", "minLength": 1},
        "evidence_kind": {
          "enum": [
            "pending",
            "external_gene_disjoint_annotation",
            "development_donor_cross_fitted_gene_disjoint_annotation",
            "orthogonal_modality_annotation"
          ]
        },
        "annotation_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "ordered_annotation_feature_ids": {"$ref": "#/$defs/strings"},
        "ordered_annotation_feature_ids_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "ordered_target_gene_ids": {"$ref": "#/$defs/strings"},
        "ordered_target_gene_ids_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "annotation_target_overlap_count": {"oneOf": [{"const": 0}, {"type": "null"}]},
        "annotation_training_scope": {
          "enum": [
            "unknown_pending_provenance",
            "external_donors_only",
            "development_donors_only",
            "orthogonal_no_rna_training"
          ]
        },
        "annotation_training_donor_ids": {"$ref": "#/$defs/strings"},
        "annotation_training_donor_ids_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "training_label_ontology_source": {
          "enum": [
            "pending",
            "external_target_disjoint_ontology",
            "de_novo_gene_disjoint_development_ontology",
            "orthogonal_modality_ontology"
          ]
        },
        "training_label_provenance_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "training_label_target_gene_overlap_count": {"oneOf": [{"const": 0}, {"type": "null"}]},
        "training_labels_establish_target_independence": {"type": "boolean"},
        "annotation_quality_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minimum_fine_type_macro_f1",
            "calibration_metric",
            "calibration_binning",
            "calibration_bin_count",
            "maximum_calibration_error",
            "minimum_major_class_sensitivity",
            "minimum_prediction_coverage_fraction",
            "abstention_method",
            "confidence_threshold",
            "abstain_label",
            "tie_breaking",
            "probability_sum_tolerance",
            "per_validation_donor_metrics_required",
            "validation_designs_by_evidence_kind"
          ],
          "properties": {
            "minimum_fine_type_macro_f1": {"type": "number", "minimum": 0.7, "maximum": 1.0},
            "calibration_metric": {"const": "multiclass_expected_calibration_error"},
            "calibration_binning": {"const": "equal_width_confidence_bins"},
            "calibration_bin_count": {"const": 10},
            "maximum_calibration_error": {"type": "number", "minimum": 0.0, "maximum": 0.1},
            "minimum_major_class_sensitivity": {"type": "number", "minimum": 0.5, "maximum": 1.0},
            "minimum_prediction_coverage_fraction": {"type": "number", "minimum": 0.8, "maximum": 1.0},
            "abstention_method": {"const": "maximum_probability_below_threshold"},
            "confidence_threshold": {"type": "number", "minimum": 0.5, "exclusiveMaximum": 1.0},
            "abstain_label": {"const": "__ABSTAIN__"},
            "tie_breaking": {"const": "ordered_fine_type_ids"},
            "probability_sum_tolerance": {
              "type": "number",
              "exclusiveMinimum": 0.0,
              "maximum": 0.000001
            },
            "per_validation_donor_metrics_required": {"const": true},
            "validation_designs_by_evidence_kind": {
              "const": {
                "external_gene_disjoint_annotation": "external_donor_held_out",
                "development_donor_cross_fitted_gene_disjoint_annotation": "leave_one_development_donor_out",
                "orthogonal_modality_annotation": "orthogonal_modality_validation"
              }
            }
          }
        },
        "locked_donors_used_for_training": {"oneOf": [{"type": "boolean"}, {"type": "null"}]},
        "same_cohort_annotation": {"type": "boolean"},
        "cross_fitting_method": {"enum": ["pending", "not_applicable", "leave_one_donor_out"]},
        "cross_fitting_receipt_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "establishes_full_target_independence": {"type": "boolean"},
        "limitation": {"type": "string", "minLength": 1}
      }
    },
    "locked_at": {"type": "string", "format": "date-time"},
    "locked_content_sha256": {"$ref": "#/$defs/sha256"},
    "opening": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"study_stage": {"const": "measurement_development"}}},
      "then": {
        "required": ["target_panel_strategy"],
        "properties": {
          "hypothesis_ids": {"const": ["H-MEAS"]},
          "randomization": {
            "required": ["transcript_split_salt", "donor_cross_fit_seed", "selection_partition"],
            "properties": {"selection_partition": {"const": "development_only"}}
          },
          "coverage_requirements": {
            "required": [
              "minimum_coverage_fraction",
              "minimum_reference_cells_per_stratum",
              "minimum_evaluation_cells_per_stratum",
              "minimum_development_donors_per_fine_type",
              "minimum_locked_donors_per_fine_type",
              "maximum_reference_evaluation_row_overlap",
              "maximum_reference_evaluation_block_overlap",
              "same_section_source_overlap_allowed"
            ],
            "properties": {
              "minimum_locked_donors_per_fine_type": {"const": 0},
              "same_section_source_overlap_allowed": {"const": true}
            }
          },
          "primary_endpoint": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "target_variant", "authorizes_target_selection"],
            "properties": {
              "name": {"const": "nucleus_overlap_within_fine_type_donor_cross_fitted_reliability"},
              "target_variant": {"const": "nucleus_overlapping_transcripts"},
              "authorizes_target_selection": {"const": true}
            }
          },
          "decision_thresholds": {
            "required": [
              "maximum_annotation_nucleus_p95_um",
              "maximum_annotation_cell_p95_um",
              "maximum_cell_nucleus_p95_um",
              "maximum_registration_nucleus_diameter_ratio_p95",
              "maximum_registration_nearest_neighbor_ratio_p95",
              "best_registration_quality_max_fraction_of_limit",
              "intermediate_registration_quality_max_fraction_of_limit",
              "maximum_registration_outlier_fraction",
              "maximum_nucleus_outside_cell_fraction",
              "minimum_nucleus_cell_area_ratio",
              "maximum_nucleus_cell_area_ratio",
              "maximum_segmentation_outlier_fraction",
              "maximum_crop_padding_p95",
              "mostly_padded_cutoff",
              "maximum_mostly_padded_fraction",
              "minimum_within_fine_type_reliability",
              "minimum_reliability_rows",
              "required_opposite_pool_guard_um",
              "minimum_common_reliable_genes"
            ],
            "properties": {
              "maximum_annotation_nucleus_p95_um": {"const": 8.0},
              "maximum_annotation_cell_p95_um": {"const": 12.0},
              "maximum_cell_nucleus_p95_um": {"const": 8.0},
              "maximum_registration_nucleus_diameter_ratio_p95": {"const": 0.5},
              "maximum_registration_nearest_neighbor_ratio_p95": {"const": 0.5},
              "best_registration_quality_max_fraction_of_limit": {"const": 0.25},
              "intermediate_registration_quality_max_fraction_of_limit": {"const": 0.6},
              "maximum_registration_outlier_fraction": {"const": 0.05},
              "maximum_nucleus_outside_cell_fraction": {"const": 0.01},
              "minimum_nucleus_cell_area_ratio": {"const": 0.05},
              "maximum_nucleus_cell_area_ratio": {"const": 0.95},
              "maximum_segmentation_outlier_fraction": {"const": 0.05},
              "maximum_crop_padding_p95": {"const": 0.25},
              "mostly_padded_cutoff": {"const": 0.5},
              "maximum_mostly_padded_fraction": {"const": 0.01},
              "minimum_within_fine_type_reliability": {"const": 0.4},
              "minimum_reliability_rows": {"const": 40},
              "required_opposite_pool_guard_um": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "minimum_common_reliable_genes": {"type": "integer", "minimum": 1}
            }
          }
        },
        "not": {
          "anyOf": [
            {"required": ["prerequisites"]},
            {"required": ["encoder"]},
            {"required": ["crop_protocols"]},
            {"required": ["reference_splits"]},
            {"required": ["target_gene_panel_sha256"]},
            {"required": ["technical_covariates"]},
            {"required": ["controls"]},
            {"required": ["hyperparameter_grid"]},
            {"required": ["morphology_gate"]},
            {"required": ["locked_measurement_audit"]}
          ]
        }
      },
      "else": {
        "properties": {
          "primary_endpoint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "condition_on",
              "decision_rule",
              "donor_type_macro",
              "donor_section_type_macro"
            ],
            "properties": {
              "name": {"const": "joint_donor_type_and_donor_section_type_macro_residual_coordinate_r2"},
              "condition_on": {"const": "fine_type"},
              "decision_rule": {"const": "both_endpoints_must_meet_frozen_minimum"},
              "donor_type_macro": {
                "type": "object",
                "additionalProperties": false,
                "required": ["metric", "minimum_effect"],
                "properties": {
                  "metric": {"const": "donor_equal_type_equal_residual_coordinate_r2"},
                  "minimum_effect": {"const": 0.05}
                }
              },
              "donor_section_type_macro": {
                "type": "object",
                "additionalProperties": false,
                "required": ["metric", "minimum_effect"],
                "properties": {
                  "metric": {"const": "donor_equal_section_equal_type_equal_residual_coordinate_r2"},
                  "minimum_effect": {"const": 0.05}
                }
              }
            }
          },
          "coverage_requirements": {
            "required": [
              "maximum_reference_evaluation_absolute_smd",
              "maximum_reference_evaluation_categorical_total_variation",
              "minimum_reference_cells_per_donor_section_type",
              "minimum_evaluation_cells_per_donor_section_type"
            ]
          }
        },
        "required": [
          "prerequisites",
          "encoder",
          "crop_protocols",
          "reference_splits",
          "target_gene_panel_sha256",
          "technical_covariates",
          "controls",
          "hyperparameter_grid",
          "morphology_gate",
          "locked_measurement_audit"
