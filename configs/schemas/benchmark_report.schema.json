{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEIR benchmark report envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "study_id", "study_manifest_sha256", "hypothesis_ids", "gate_id", "pass", "environment", "provenance"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^heir\\."},
    "study_id": {"type": "string", "minLength": 1},
    "study_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "hypothesis_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "gate_id": {"pattern": "^G[0-9]$"},
    "pass": {"type": "boolean"},
    "environment": {"type": "object"},
    "provenance": {"type": "object"}
  }
}

