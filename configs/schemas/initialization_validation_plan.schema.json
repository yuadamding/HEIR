{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heir.initialization_validation_plan.v1",
  "title": "HEIR frozen-initializer validation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "checkpoint",
    "evaluation_artifact",
    "label_source",
    "latent_target_source",
    "held_out_donors",
    "seeds",
    "thresholds"
  ],
  "properties": {
    "schema": {"const": "heir.initialization_validation_plan.v1"},
    "status": {"enum": ["draft", "ready"]},
    "checkpoint": {"$ref": "#/$defs/artifact"},
    "evaluation_artifact": {"$ref": "#/$defs/artifact"},
    "label_source": {"$ref": "#/$defs/artifact"},
    "latent_target_source": {"$ref": "#/$defs/artifact"},
    "held_out_donors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "seeds": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0}
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_macro_f1",
        "minimum_image_shuffle_macro_f1_delta",
        "minimum_latent_cosine",
        "minimum_image_shuffle_latent_cosine_delta",
        "maximum_latent_rmse",
        "maximum_ece",
        "maximum_brier",
        "minimum_predicted_class_occupancy_fraction",
        "minimum_per_type_support"
      ],
      "properties": {
        "minimum_macro_f1": {"type": "number", "minimum": 0.65, "maximum": 1.0},
        "minimum_image_shuffle_macro_f1_delta": {
          "type": "number",
          "minimum": 0.05,
          "maximum": 1.0
        },
        "minimum_latent_cosine": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "minimum_image_shuffle_latent_cosine_delta": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 2.0
        },
        "maximum_latent_rmse": {"type": "number", "exclusiveMinimum": 0.0},
        "maximum_ece": {"type": "number", "minimum": 0.0, "maximum": 0.10},
        "maximum_brier": {"type": "number", "minimum": 0.0, "maximum": 0.25},
        "minimum_predicted_class_occupancy_fraction": {
          "type": "number",
          "minimum": 0.75,
          "maximum": 1.0
        },
        "minimum_per_type_support": {"type": "integer", "minimum": 2}
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
