{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heir.initialization_validation_evidence.v1",
  "title": "HEIR frozen-initializer validation evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "pass",
    "checkpoint",
    "plan",
    "evidence_artifact",
    "label_source",
    "latent_target_source",
    "feature_space_id",
    "latent_space_id",
    "type_ontology_sha256",
    "training_donors",
    "held_out_donors",
    "capabilities",
    "thresholds",
    "metrics",
    "donor_metrics",
    "shuffle_controls",
    "checks",
    "execution"
  ],
  "properties": {
    "schema": {"const": "heir.initialization_validation_evidence.v1"},
    "status": {"const": "complete"},
    "pass": {"type": "boolean"},
    "checkpoint": {"$ref": "#/$defs/artifact"},
    "plan": {"$ref": "#/$defs/artifact"},
    "evidence_artifact": {"$ref": "#/$defs/artifact"},
    "label_source": {"$ref": "#/$defs/artifact"},
    "latent_target_source": {"$ref": "#/$defs/artifact"},
    "feature_space_id": {"type": "string", "minLength": 1},
    "latent_space_id": {"type": "string", "minLength": 1},
    "type_ontology_sha256": {"$ref": "#/$defs/sha256"},
    "training_donors": {"$ref": "#/$defs/donors"},
    "held_out_donors": {"$ref": "#/$defs/donors"},
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["broad_type", "image_to_latent"],
      "properties": {
        "broad_type": {"const": true},
        "image_to_latent": {"const": true}
      }
    },
    "thresholds": {"$ref": "#/$defs/thresholds"},
    "metrics": {"$ref": "#/$defs/metrics"},
    "donor_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/donor_metrics"}
    },
    "shuffle_controls": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/shuffle_control"}
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_f1",
        "image_shuffle_macro_f1_delta",
        "latent_cosine",
        "image_shuffle_latent_cosine_delta",
        "latent_rmse",
        "ece",
        "brier",
        "predicted_class_occupancy",
        "per_type_support"
      ],
      "properties": {
        "macro_f1": {"type": "boolean"},
        "image_shuffle_macro_f1_delta": {"type": "boolean"},
        "latent_cosine": {"type": "boolean"},
        "image_shuffle_latent_cosine_delta": {"type": "boolean"},
        "latent_rmse": {"type": "boolean"},
        "ece": {"type": "boolean"},
        "brier": {"type": "boolean"},
        "predicted_class_occupancy": {"type": "boolean"},
        "per_type_support": {"type": "boolean"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "seeds"],
      "properties": {
        "device": {"type": "string", "minLength": 1},
        "seeds": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 0}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "donors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_macro_f1",
        "minimum_image_shuffle_macro_f1_delta",
        "minimum_latent_cosine",
        "minimum_image_shuffle_latent_cosine_delta",
        "maximum_latent_rmse",
        "maximum_ece",
        "maximum_brier",
        "minimum_predicted_class_occupancy_fraction",
        "minimum_per_type_support"
      ],
      "properties": {
        "minimum_macro_f1": {"type": "number"},
        "minimum_image_shuffle_macro_f1_delta": {"type": "number"},
        "minimum_latent_cosine": {"type": "number"},
        "minimum_image_shuffle_latent_cosine_delta": {"type": "number"},
        "maximum_latent_rmse": {"type": "number"},
        "maximum_ece": {"type": "number"},
        "maximum_brier": {"type": "number"},
        "minimum_predicted_class_occupancy_fraction": {"type": "number"},
        "minimum_per_type_support": {"type": "number"}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "macro_f1",
        "ece",
        "brier",
        "predicted_class_occupancy_fraction",
        "minimum_per_type_support",
        "latent_cosine",
        "latent_rmse"
      ],
      "properties": {
        "macro_f1": {"type": "number"},
        "ece": {"type": "number"},
        "brier": {"type": "number"},
        "predicted_class_occupancy_fraction": {"type": "number"},
        "minimum_per_type_support": {"type": "number"},
        "latent_cosine": {"type": "number"},
        "latent_rmse": {"type": "number"}
      }
    },
    "donor_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "donor_id",
        "macro_f1",
        "ece",
        "brier",
        "predicted_class_occupancy_fraction",
        "minimum_per_type_support",
        "latent_cosine",
        "latent_rmse"
      ],
      "properties": {
        "donor_id": {"type": "string", "minLength": 1},
        "macro_f1": {"type": "number"},
        "ece": {"type": "number"},
        "brier": {"type": "number"},
        "predicted_class_occupancy_fraction": {"type": "number"},
        "minimum_per_type_support": {"type": "number"},
        "latent_cosine": {"type": "number"},
        "latent_rmse": {"type": "number"}
      }
    },
    "shuffle_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "donor_id",
        "permutation_sha256",
        "cross_type_mismatch_fraction",
        "image_shuffle_macro_f1",
        "real_minus_image_shuffle_macro_f1",
        "image_shuffle_latent_cosine",
        "real_minus_image_shuffle_latent_cosine"
      ],
      "properties": {
        "seed": {"type": "integer", "minimum": 0},
        "donor_id": {"type": "string", "minLength": 1},
        "permutation_sha256": {"$ref": "#/$defs/sha256"},
        "cross_type_mismatch_fraction": {"type": "number", "minimum": 0.5, "maximum": 1.0},
        "image_shuffle_macro_f1": {"type": "number"},
        "real_minus_image_shuffle_macro_f1": {"type": "number"},
        "image_shuffle_latent_cosine": {"type": "number"},
        "real_minus_image_shuffle_latent_cosine": {"type": "number"}
      }
    }
  }
}
