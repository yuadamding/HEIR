{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "heir.broad_type_supervised_plan.v1",
  "title": "HEIR supervised broad-cell-type development plan",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "status",
    "seeds",
    "graph",
    "molecular_residual",
    "label_policy",
    "tasks"
  ],
  "properties": {
    "schema_version": {"const": "heir.broad_type_supervised_plan.v1"},
    "status": {"enum": ["labels_pending", "ready"]},
    "seeds": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0}
    },
    "graph": {
      "type": "object",
      "required": ["enabled"],
      "properties": {"enabled": {"const": false}}
    },
    "molecular_residual": {
      "type": "object",
      "required": ["enabled"],
      "properties": {"enabled": {"const": false}}
    },
    "label_policy": {
      "type": "object",
      "required": [
        "generated_by_pipeline",
        "independent_of_heir_predictions_required",
        "roi_compartment_required",
        "reviewer_confidence_required"
      ],
      "properties": {
        "generated_by_pipeline": {"const": false},
        "independent_of_heir_predictions_required": {"const": true},
        "roi_compartment_required": {"const": true},
        "reviewer_confidence_required": {"const": true}
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "split_policy", "ontology", "datasets"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "split_policy": {"enum": ["grouped_roi", "leave_one_donor_out"]},
          "ontology": {"$ref": "#/$defs/artifact"},
          "datasets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["section_id", "donor_id", "features", "labels"],
              "properties": {
                "section_id": {"type": "string", "minLength": 1},
                "donor_id": {"type": "string", "minLength": 1},
                "features": {"$ref": "#/$defs/artifact"},
                "labels": {"$ref": "#/$defs/pendingArtifact"}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "pendingArtifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        }
      }
    }
  }
}
